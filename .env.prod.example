# ============================================================
# AgendaZap — variáveis de ambiente para PRODUÇÃO
# Copie este arquivo para .env e preencha os valores
# ============================================================

# --- Banco de dados ---
POSTGRES_USER=agendazap
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE

# --- Redis ---
REDIS_PASSWORD=TROQUE_POR_SENHA_FORTE

# --- Evolution API (WhatsApp) ---
# EVOLUTION_API_URL é o endereço interno do container (não mude)
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=TROQUE_POR_CHAVE_FORTE_MIN_32_CHARS

# --- Provider de IA: "claude" ou "openai" ---
AI_PROVIDER=openai

# Claude (Anthropic) — necessário se AI_PROVIDER=claude
CLAUDE_API_KEY=sk-ant-...

# OpenAI — necessário se AI_PROVIDER=openai
OPENAI_API_KEY=sk-proj-...

# --- Google Calendar ---
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=https://app.meuagendazap.com.br/admin/google/callback

# --- URLs públicas ---
# SERVER_URL: usado para registrar o webhook do WhatsApp na Evolution API
SERVER_URL=https://app.meuagendazap.com.br
# ADMIN_URL: origem permitida no CORS para o painel administrativo
ADMIN_URL=https://app.meuagendazap.com.br/painel

# --- JWT ---
JWT_SECRET=TROQUE_POR_STRING_ALEATORIA_LONGA_64_CHARS

# --- App ---
PORT=3000
NODE_ENV=production

# --- Seed da primeira clínica (executado uma única vez) ---
# Só é necessário no primeiro deploy para criar o usuário admin inicial
CLINIC_NAME=Nome da Clínica
CLINIC_PHONE=5511999999999
ADMIN_EMAIL=admin@suaclinica.com.br
ADMIN_SENHA=TROQUE_POR_SENHA_FORTE

# --- Whitelist de testes (desenvolvimento) ---
# Deixe vazio em produção para processar todos os números
TEST_PHONE_WHITELIST=
