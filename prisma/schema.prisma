generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Clinica {
  id          String   @id @default(uuid())
  nome        String
  telefoneWpp String   @unique @map("telefone_wpp")
  endereco    String?
  configJson          Json?    @map("config_json")
  googleRefreshToken  String?  @map("google_refresh_token")
  ativo               Boolean  @default(true)
  createdAt           DateTime @default(now()) @map("created_at")

  profissionais   Profissional[]
  pacientes       Paciente[]
  agendamentos    Agendamento[]
  conversas       Conversa[]
  estadosConversa EstadoConversa[]
  usuariosAdmin   UsuarioAdmin[]
  convenios       Convenio[]

  @@map("clinicas")
}

model Profissional {
  id                  String   @id @default(uuid())
  clinicaId           String   @map("clinica_id")
  nome                String
  especialidade       String
  calendarId          String?  @map("calendar_id")
  duracaoConsultaMin  Int      @default(30) @map("duracao_consulta_min")
  atendeParticular    Boolean  @default(true) @map("atende_particular")
  ativo               Boolean  @default(true)
  createdAt           DateTime @default(now()) @map("created_at")

  clinica      Clinica                @relation(fields: [clinicaId], references: [id], onDelete: Cascade)
  agendamentos Agendamento[]
  convenios    ProfissionalConvenio[]

  @@map("profissionais")
}

model Paciente {
  id            String   @id @default(uuid())
  clinicaId     String   @map("clinica_id")
  nome          String?
  telefone      String
  email         String?
  optInLembrete Boolean  @default(true) @map("opt_in_lembrete")
  createdAt     DateTime @default(now()) @map("created_at")

  clinica      Clinica       @relation(fields: [clinicaId], references: [id], onDelete: Cascade)
  agendamentos Agendamento[]
  conversas    Conversa[]

  @@unique([clinicaId, telefone, nome])
  @@map("pacientes")
}

model Agendamento {
  id               String            @id @default(uuid())
  clinicaId        String            @map("clinica_id")
  profissionalId   String            @map("profissional_id")
  pacienteId       String            @map("paciente_id")
  dataHora         DateTime          @map("data_hora")
  duracaoMin       Int               @default(30) @map("duracao_min")
  status           StatusAgendamento @default(agendado)
  confirmedBy      String?           @map("confirmed_by")
  calendarEventId   String?           @map("calendar_event_id")
  lembreteEnviadoAt DateTime?         @map("lembrete_enviado_at")
  reminderJobId     String?           @map("reminder_job_id")
  createdAt         DateTime          @default(now()) @map("created_at")

  tipoConsulta     TipoConsultaEnum  @default(particular) @map("tipo_consulta")
  convenioId       String?           @map("convenio_id")

  clinica      Clinica      @relation(fields: [clinicaId], references: [id], onDelete: Cascade)
  profissional Profissional @relation(fields: [profissionalId], references: [id], onDelete: Cascade)
  paciente     Paciente     @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  convenio     Convenio?    @relation(fields: [convenioId], references: [id], onDelete: SetNull)

  @@map("agendamentos")
}

model Conversa {
  id           String        @id @default(uuid())
  clinicaId    String        @map("clinica_id")
  pacienteId   String?       @map("paciente_id")
  telefone     String
  direcao      DirecaoMensagem
  mensagem     String
  metadataJson Json?         @map("metadata_json")
  createdAt    DateTime      @default(now()) @map("created_at")

  clinica  Clinica   @relation(fields: [clinicaId], references: [id], onDelete: Cascade)
  paciente Paciente? @relation(fields: [pacienteId], references: [id], onDelete: SetNull)

  @@map("conversas")
}

model EstadoConversa {
  telefone     String
  clinicaId    String        @map("clinica_id")
  estado       EstadoBot     @default(inicio)
  contextoJson Json?         @map("contexto_json")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  clinica Clinica @relation(fields: [clinicaId], references: [id], onDelete: Cascade)

  @@id([telefone, clinicaId])
  @@map("estado_conversa")
}

model UsuarioAdmin {
  id        String   @id @default(uuid())
  clinicaId String   @map("clinica_id")
  email     String   @unique
  senhaHash String   @map("senha_hash")
  createdAt DateTime @default(now()) @map("created_at")

  clinica Clinica @relation(fields: [clinicaId], references: [id], onDelete: Cascade)

  @@map("usuarios_admin")
}

model UsuarioOwner {
  id        String   @id @default(uuid())
  email     String   @unique
  senhaHash String   @map("senha_hash")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("usuarios_owner")
}

enum StatusAgendamento {
  agendado
  confirmado
  cancelado
  concluido
  no_show
}

enum DirecaoMensagem {
  entrada
  saida
}

enum EstadoBot {
  inicio
  escolhendo_especialidade
  escolhendo_convenio
  escolhendo_plano
  escolhendo_horario
  confirmando
  concluido
  aguardando_resposta_lembrete
}

enum TipoConsultaEnum {
  particular
  convenio
}

model Convenio {
  id        String   @id @default(uuid())
  clinicaId String   @map("clinica_id")
  nome      String
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  clinica       Clinica                @relation(fields: [clinicaId], references: [id], onDelete: Cascade)
  profissionais ProfissionalConvenio[]
  agendamentos  Agendamento[]

  @@unique([clinicaId, nome])
  @@map("convenios")
}

model ProfissionalConvenio {
  profissionalId String @map("profissional_id")
  convenioId     String @map("convenio_id")

  profissional Profissional @relation(fields: [profissionalId], references: [id], onDelete: Cascade)
  convenio     Convenio     @relation(fields: [convenioId], references: [id], onDelete: Cascade)

  @@id([profissionalId, convenioId])
  @@map("profissional_convenio")
}
