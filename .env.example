# Banco de dados PostgreSQL
DATABASE_URL="postgresql://agendazap:agendazap123@localhost:5432/agendazap"

# Redis
REDIS_URL="redis://localhost:6379"

# Evolution API (WhatsApp)
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="seu-token-aqui"

# Claude API (Anthropic)
CLAUDE_API_KEY="sk-ant-..."

# Google Calendar API
GOOGLE_CLIENT_ID="seu-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="seu-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/admin/google/callback"

# Painel admin (usado no redirecionamento pós-OAuth e no CORS)
ADMIN_URL="http://localhost:5173"

# Painel do proprietário (owner)
OWNER_URL="http://localhost:5174"

# JWT
JWT_SECRET="troque-por-uma-string-secreta-longa-em-producao"

# Servidor
PORT=3000
NODE_ENV=development
SERVER_URL="http://host.docker.internal:3000"

# Seed — identifica a clínica e cria o usuário admin do painel
# CLINIC_PHONE: número WhatsApp da clínica no formato DDI+DDD+número (sem + ou espaços)
# Deve ser o mesmo número configurado na Evolution API / conectado ao WhatsApp
CLINIC_PHONE=55119XXXXXXXX
CLINIC_NAME="Nome da Clínica"
ADMIN_EMAIL=admin@suaclinica.com.br
# Em produção: use uma senha forte (mínimo 12 caracteres).
# O seed recusa valor "admin123" quando NODE_ENV=production.
ADMIN_SENHA=troque-por-senha-forte-aqui

# Seed do proprietário da solução (opcionais — seed pulado se ausentes)
OWNER_EMAIL=
OWNER_SENHA=
